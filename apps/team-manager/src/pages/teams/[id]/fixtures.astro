---
import Layout from '~/layouts/Layout.astro';
import { getTeam, listEvents } from '~/lib/store';

export const prerender = false;

const { id } = Astro.params;
const team = await getTeam(id!);
if (!team) return Astro.redirect('/');
const events = await listEvents(team.id);
const now = new Date().toISOString();
const upcoming = events.filter((e) => e.startsAt >= now);
const past = events.filter((e) => e.startsAt < now).reverse();
---
<Layout title={`Fixtures — ${team.name}`} teamId={team.id} teamName={team.name}>
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-semibold tracking-tight">Fixtures</h1>
    <button type="button" id="add-event-btn" class="btn-primary">+ New fixture</button>
  </div>

  <dialog id="event-dialog" class="rounded-lg p-0 backdrop:bg-slate-900/50">
    <form id="event-form" class="card w-[min(90vw,28rem)] p-5 space-y-4 border-0 shadow-lg">
      <h2 class="font-medium">New fixture</h2>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="sm:col-span-2">
          <label class="label">Title</label>
          <input name="title" required class="input" placeholder="Race vs. Albacore Fleet" />
        </div>
        <div>
          <label class="label">Type</label>
          <select name="type" class="input">
            <option value="practice">Practice</option>
            <option value="match">Match</option>
            <option value="race">Race</option>
            <option value="session">Session</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div>
          <label class="label">Location</label>
          <input name="location" class="input" />
        </div>
        <div>
          <label class="label">Starts</label>
          <input name="startsAt" type="datetime-local" required class="input" />
        </div>
        <div>
          <label class="label">Ends</label>
          <input name="endsAt" type="datetime-local" class="input" />
        </div>
        <div class="sm:col-span-2">
          <label class="label">Notes</label>
          <textarea name="notes" rows="2" class="input"></textarea>
        </div>
      </div>
      <div class="flex items-center justify-end gap-2">
        <button type="button" id="cancel-event" class="btn-secondary">Cancel</button>
        <button type="submit" class="btn-primary">Save</button>
      </div>
    </form>
  </dialog>

  {events.length === 0 ? (
    <div class="card p-8 text-center text-sm text-slate-500">
      No fixtures yet. Add your first race, match, or practice.
    </div>
  ) : (
    <>
      <section class="mb-8">
        <h2 class="font-medium mb-3">Upcoming</h2>
        {upcoming.length === 0 ? (
          <p class="text-sm text-slate-500">Nothing on the schedule.</p>
        ) : (
          <ul class="space-y-2">
            {upcoming.map((event) => (
              <li class="card p-4 flex items-start justify-between gap-4">
                <div>
                  <div class="font-medium">{event.title}</div>
                  <div class="text-xs text-slate-500 mt-0.5">
                    {new Date(event.startsAt).toLocaleString()}
                    {event.location && ` · ${event.location}`}
                  </div>
                  <span class="text-[10px] uppercase tracking-wide text-slate-400 mt-2 inline-block">
                    {event.type}
                  </span>
                </div>
                <button
                  type="button"
                  class="btn-secondary text-xs delete-event"
                  data-event-id={event.id}
                >
                  Remove
                </button>
              </li>
            ))}
          </ul>
        )}
      </section>

      {past.length > 0 && (
        <section>
          <h2 class="font-medium mb-3 text-slate-500">Past</h2>
          <ul class="space-y-2">
            {past.map((event) => (
              <li class="card p-3 flex items-center justify-between opacity-75">
                <div>
                  <div class="text-sm">{event.title}</div>
                  <div class="text-xs text-slate-500">
                    {new Date(event.startsAt).toLocaleString()}
                  </div>
                </div>
                <button
                  type="button"
                  class="btn-secondary text-xs delete-event"
                  data-event-id={event.id}
                >
                  Remove
                </button>
              </li>
            ))}
          </ul>
        </section>
      )}
    </>
  )}

  <script is:inline define:vars={{ teamId: team.id }}>
    const dlg = document.getElementById('event-dialog');
    const form = document.getElementById('event-form');

    document.getElementById('add-event-btn').addEventListener('click', () => {
      form.reset();
      dlg.showModal();
    });
    document.getElementById('cancel-event').addEventListener('click', () => dlg.close());

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const startsAt = fd.get('startsAt');
      const endsAt = fd.get('endsAt');
      const body = {
        teamId,
        title: fd.get('title'),
        type: fd.get('type'),
        location: fd.get('location'),
        notes: fd.get('notes'),
        startsAt: startsAt ? new Date(startsAt).toISOString() : null,
        endsAt: endsAt ? new Date(endsAt).toISOString() : undefined,
      };
      const res = await fetch('/api/events', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (res.ok) window.location.reload();
    });

    document.querySelectorAll('.delete-event').forEach((btn) => {
      btn.addEventListener('click', async () => {
        if (!confirm('Remove this fixture?')) return;
        const id = btn.dataset.eventId;
        const res = await fetch(`/api/events/${id}`, { method: 'DELETE' });
        if (res.ok) window.location.reload();
      });
    });
  </script>
</Layout>
