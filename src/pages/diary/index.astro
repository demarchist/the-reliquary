---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DiaryEntry from '../../components/DiaryEntry.astro';
import { getCollection } from 'astro:content';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allEntries = await getCollection('diary');
const allInterludes = await getCollection('interludes');
const allInterludeGroupsMeta = await getCollection('interludeGroups');

const allChapterMeta = await getCollection('chapters');
const chapterSummaries = new Map(allChapterMeta.map(c => [c.data.chapter, c.data.summary]));

// Sort diary entries by chapter then session
allEntries.sort((a, b) => {
  if (a.data.chapter !== b.data.chapter) return a.data.chapter - b.data.chapter;
  return a.data.session - b.data.session;
});

// Group diary entries by chapter
const chapters = new Map<number, { title?: string; entries: typeof allEntries }>();
for (const entry of allEntries) {
  const ch = entry.data.chapter;
  if (!chapters.has(ch)) {
    chapters.set(ch, { title: entry.data.chapterTitle, entries: [] });
  }
  chapters.get(ch)!.entries.push(entry);
}

// Build interlude groups metadata sorted by interlude number
allInterludeGroupsMeta.sort((a, b) => a.data.interlude - b.data.interlude);

// Map afterChapter → sorted interlude group metadata
const interludeGroupsByAfterChapter = new Map<number, typeof allInterludeGroupsMeta>();
for (const g of allInterludeGroupsMeta) {
  const ch = g.data.afterChapter;
  if (!interludeGroupsByAfterChapter.has(ch)) {
    interludeGroupsByAfterChapter.set(ch, []);
  }
  interludeGroupsByAfterChapter.get(ch)!.push(g);
}

// Group interlude sessions by interlude number, sorted by session
const interludeSessionsByGroup = new Map<number, typeof allInterludes>();
for (const il of allInterludes) {
  const n = il.data.interlude;
  if (!interludeSessionsByGroup.has(n)) {
    interludeSessionsByGroup.set(n, []);
  }
  interludeSessionsByGroup.get(n)!.push(il);
}
for (const sessions of interludeSessionsByGroup.values()) {
  sessions.sort((a, b) => a.data.session - b.data.session);
}

const hasOutline = chapters.size > 0;
---

<BaseLayout title="Campaign Diary">
  <div class:list={[hasOutline && 'lg:grid lg:grid-cols-[180px_1fr] lg:gap-8']}>
    <!-- Chapter Outline -->
    {hasOutline && (
      <aside class="hidden lg:block">
        <nav id="section-outline" class="sticky top-20">
          <h2 class="font-serif text-sm font-semibold text-ink-700 mb-3">Chapters</h2>
          <ul class="space-y-1.5 border-l border-parchment-300">
            {[...chapters.entries()].map(([chapterNum, chapter]) => (
              <>
                <li>
                  <a
                    href={`#chapter-${chapterNum}`}
                    class="outline-link block pl-3 text-xs leading-snug text-ink-500 no-underline hover:text-accent-600 transition-colors border-l-2 border-transparent -ml-px"
                    data-slug={`chapter-${chapterNum}`}
                  >
                    Ch. {chapterNum}{chapter.title ? `: ${chapter.title}` : ''}
                  </a>
                </li>
                {(interludeGroupsByAfterChapter.get(chapterNum) ?? []).map(g => (
                  <li>
                    <a
                      href={`#interlude-${g.data.interlude}`}
                      class="outline-link block pl-3 text-xs leading-snug text-ink-500 no-underline hover:text-accent-600 transition-colors border-l-2 border-transparent -ml-px italic"
                      data-slug={`interlude-${g.data.interlude}`}
                    >
                      Interludes: {g.data.title}
                    </a>
                  </li>
                ))}
              </>
            ))}
          </ul>
        </nav>
      </aside>
    )}

    <div>
  <h1 class="font-serif text-3xl font-bold text-ink-900 mb-2">Campaign Diary</h1>
  <p class="text-ink-400 mb-6">Session-by-session accounts of <em>The Rise of Atropos</em>.</p>

  <div id="search" class="mb-8"></div>

  <link href={`${base}/pagefind/pagefind-ui.css`} rel="stylesheet" />
  <script is:inline define:vars={{ base }}>
    window.addEventListener('DOMContentLoaded', function() {
      var script = document.createElement('script');
      script.src = base + '/pagefind/pagefind-ui.js';
      script.onload = function() {
        new PagefindUI({
          element: '#search',
          showSubResults: true,
          showImages: false,
          baseUrl: base + '/',
        });
      };
      document.head.appendChild(script);
    });
  </script>

  {allEntries.length === 0 ? (
    <div class="text-center py-12 text-ink-400">
      <p>No diary entries yet. Run the conversion script to import campaign sessions.</p>
      <code class="text-sm mt-2 block">python scripts/convert-docx.py</code>
    </div>
  ) : (
    <div class="space-y-8">
      {[...chapters.entries()].map(([chapterNum, chapter]) => (
        <>
          <section>
            <h2 id={`chapter-${chapterNum}`} class="font-serif text-xl font-semibold text-ink-800 mb-3 pb-2 border-b border-parchment-200">
              Chapter {chapterNum}{chapter.title ? `: ${chapter.title}` : ''}
            </h2>
            {chapterSummaries.has(chapterNum) && (
              <p class="text-sm text-ink-500 italic mb-4 leading-relaxed">{chapterSummaries.get(chapterNum)}</p>
            )}
            <div>
              {chapter.entries.map(entry => (
                <DiaryEntry
                  title={entry.data.title}
                  chapter={entry.data.chapter}
                  chapterTitle={entry.data.chapterTitle}
                  session={entry.data.session}
                  summary={entry.data.summary}
                  slug={entry.id}
                />
              ))}
            </div>
          </section>
          {(interludeGroupsByAfterChapter.get(chapterNum) ?? []).map(g => (
            <section>
              <h2 id={`interlude-${g.data.interlude}`} class="font-serif text-xl font-semibold text-ink-800 mb-3 pb-2 border-b border-parchment-200 italic">
                Interludes: {g.data.title}
              </h2>
              <p class="text-sm text-ink-500 italic mb-4 leading-relaxed">{g.data.summary}</p>
              <div>
                {(interludeSessionsByGroup.get(g.data.interlude) ?? []).map(entry => (
                  <DiaryEntry
                    title={entry.data.title}
                    interlude={entry.data.interlude}
                    session={entry.data.session}
                    summary={entry.data.summary}
                    slug={entry.id}
                  />
                ))}
              </div>
            </section>
          ))}
        </>
      ))}
    </div>
  )}
    </div>
  </div>

  <script>
    const links = document.querySelectorAll<HTMLAnchorElement>('.outline-link');
    if (links.length > 0) {
      const slugs = Array.from(links).map(l => l.dataset.slug!);
      const headings = slugs.map(s => document.getElementById(s)).filter(Boolean) as HTMLElement[];

      function setActive(slug: string) {
        links.forEach(l => l.classList.toggle('active', l.dataset.slug === slug));
      }

      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              setActive(entry.target.id);
            }
          }
        },
        { rootMargin: '0px 0px -80% 0px', threshold: 0 }
      );

      headings.forEach(h => observer.observe(h));
    }
  </script>
</BaseLayout>
