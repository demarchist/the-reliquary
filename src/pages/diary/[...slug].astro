---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { categoryColors } from '../../utils/category-colors';

export async function getStaticPaths() {
  const diaryEntries = await getCollection('diary');
  const interludeEntries = await getCollection('interludes');
  return [
    ...diaryEntries.map(entry => ({
      params: { slug: entry.id },
      props: { entry, isInterlude: false },
    })),
    ...interludeEntries.map(entry => ({
      params: { slug: entry.id },
      props: { entry, isInterlude: true },
    })),
  ];
}

const { entry, isInterlude } = Astro.props;
const { Content, headings } = await render(entry);
const h2Headings = headings.filter(h => h.depth === 2);

// Build a merged, ordered list of all entries for prev/next navigation.
// Order: diary entries sorted by chapter/session, with interludes inserted after
// the last chapter-14 entry.
const allDiary = await getCollection('diary');
allDiary.sort((a, b) => {
  if (a.data.chapter !== b.data.chapter) return a.data.chapter - b.data.chapter;
  return a.data.session - b.data.session;
});
const allInterludes = await getCollection('interludes');
allInterludes.sort((a, b) => a.data.session - b.data.session);

type NavEntry = { id: string; title: string };
const ordered: NavEntry[] = [];
let interludesInserted = false;
for (const e of allDiary) {
  ordered.push({ id: e.id, title: e.data.title });
  if (!interludesInserted && e.data.chapter === 14) {
    // Check if this is the last ch.14 entry
    const nextDiary = allDiary[allDiary.indexOf(e) + 1];
    if (!nextDiary || nextDiary.data.chapter !== 14) {
      for (const il of allInterludes) {
        ordered.push({ id: il.id, title: il.data.title });
      }
      interludesInserted = true;
    }
  }
}
// If no ch.14 exists yet, append interludes at the end
if (!interludesInserted) {
  for (const il of allInterludes) {
    ordered.push({ id: il.id, title: il.data.title });
  }
}

const currentIndex = ordered.findIndex(e => e.id === entry.id);
const prev = currentIndex > 0 ? ordered[currentIndex - 1] : null;
const next = currentIndex < ordered.length - 1 ? ordered[currentIndex + 1] : null;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Load wiki entries for entity sidebar lookups
const allWiki = await getCollection('wiki');
const wikiBySlug = new Map(allWiki.map(w => [w.id, w]));

// Build entity sidebar sections
const entitySections = [
  { label: 'People', key: 'people' as const, slugs: entry.data.people || [] },
  { label: 'Places', key: 'places' as const, slugs: entry.data.places || [] },
  { label: 'Things', key: 'things' as const, slugs: entry.data.things || [] },
  { label: 'Factions', key: 'factions' as const, slugs: entry.data.factions || [] },
  { label: 'Events', key: 'events' as const, slugs: entry.data.events || [] },
].filter(s => s.slugs.length > 0);

const hasEntities = entitySections.length > 0;
const hasOutline = h2Headings.length > 0;

// Build the header label
let headerLabel: string;
if (isInterlude) {
  headerLabel = `Interlude ${entry.data.session}`;
} else {
  const d = entry.data as { chapter: number; chapterTitle?: string; session: number };
  headerLabel = `Chapter ${d.chapter}${d.chapterTitle ? `: ${d.chapterTitle}` : ''} · Session ${d.session}`;
}
---

<BaseLayout title={entry.data.title} extraWide={hasOutline && hasEntities}>
  <article>
    <div class="mb-6">
      <a href={`${base}/diary/`} class="text-sm text-ink-400 hover:text-accent-600 no-underline">&larr; Back to Diary</a>
    </div>

    <div class:list={[
      hasOutline && hasEntities && 'lg:grid lg:grid-cols-[1fr_280px] lg:gap-8 xl:grid-cols-[180px_1fr_280px]',
      hasOutline && !hasEntities && 'lg:grid lg:grid-cols-[180px_1fr] lg:gap-8',
      !hasOutline && hasEntities && 'lg:grid lg:grid-cols-[1fr_280px] lg:gap-8',
    ]}>
      <!-- Section Outline -->
      {hasOutline && (
        <aside class:list={[
          hasEntities ? 'hidden xl:block' : 'hidden lg:block',
        ]}>
          <nav id="section-outline" class="sticky top-20">
            <h2 class="font-serif text-sm font-semibold text-ink-700 mb-3">Outline</h2>
            <ul class="space-y-1.5 border-l border-parchment-300">
              {h2Headings.map(h => (
                <li>
                  <a
                    href={`#${h.slug}`}
                    class="outline-link block pl-3 text-xs leading-snug text-ink-500 no-underline hover:text-accent-600 transition-colors border-l-2 border-transparent -ml-px"
                    data-slug={h.slug}
                  >
                    {h.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      )}

      <!-- Main Content -->
      <div>
        <header class="mb-8">
          <div class="text-sm text-ink-400 mb-1 font-mono" data-pagefind-meta={isInterlude ? 'chapter:Interludes' : `chapter:Chapter ${(entry.data as any).chapter}`}>
            {headerLabel}
          </div>
          <h1 class="font-serif text-3xl font-bold text-ink-900" data-pagefind-meta="title">{entry.data.title}</h1>
          {entry.data.summary && (
            <p class="mt-2 text-ink-500 italic">{entry.data.summary}</p>
          )}
        </header>

        <div class="prose" data-pagefind-body>
          <Content />
        </div>

        <nav class="flex justify-between mt-12 pt-6 border-t border-parchment-200 text-sm">
          {prev ? (
            <a href={`${base}/diary/${prev.id}/`} class="text-ink-500 hover:text-accent-600 no-underline">
              &larr; {prev.title}
            </a>
          ) : <span />}
          {next ? (
            <a href={`${base}/diary/${next.id}/`} class="text-ink-500 hover:text-accent-600 no-underline">
              {next.title} &rarr;
            </a>
          ) : <span />}
        </nav>
      </div>

      <!-- Entity Sidebar -->
      {hasEntities && (
        <aside class="mt-8 lg:mt-0">
          <div class="bg-parchment-100 rounded-lg p-4 lg:sticky lg:top-20 space-y-4">
            <h2 class="font-serif text-lg font-semibold text-ink-800">Featured In</h2>
            {entitySections.map(section => (
              <div>
                <h3 class="text-xs font-semibold text-ink-500 uppercase tracking-wide mb-1.5">{section.label}</h3>
                <div class="flex flex-wrap gap-1.5">
                  {section.slugs.map(slug => {
                    const wiki = wikiBySlug.get(slug);
                    return wiki ? (
                      <a
                        href={`${base}/wiki/${slug}/`}
                        class:list={['text-xs font-medium px-2 py-0.5 rounded-full no-underline hover:opacity-80 transition-opacity', categoryColors[section.label] || 'bg-parchment-200 text-ink-600']}
                      >
                        {wiki.data.title}
                      </a>
                    ) : null;
                  })}
                </div>
              </div>
            ))}
          </div>
        </aside>
      )}
    </div>
  </article>

  {hasOutline && (
    <script>
      const links = document.querySelectorAll<HTMLAnchorElement>('.outline-link');
      if (links.length > 0) {
        const slugs = Array.from(links).map(l => l.dataset.slug!);
        const headings = slugs.map(s => document.getElementById(s)).filter(Boolean) as HTMLElement[];

        function setActive(slug: string) {
          links.forEach(l => l.classList.toggle('active', l.dataset.slug === slug));
        }

        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                setActive(entry.target.id);
              }
            }
          },
          { rootMargin: '0px 0px -80% 0px', threshold: 0 }
        );

        headings.forEach(h => observer.observe(h));
      }
    </script>
  )}
</BaseLayout>
